<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <stroke android:width="1dp" android:color="@color/outline01" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <stroke android:width="1dp" android:color="@color/outline04" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="1dp" android:color="@color/outline18" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
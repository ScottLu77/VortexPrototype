<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
                <shape>
                    <corners android:radius="8dp" />
                    <gradient
                        android:startColor="@color/surface10"
                        android:centerColor="@color/surface10"
                        android:centerY="0.75"
                        android:endColor="@color/surface10"
                        android:angle="270" />
                </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="8dp" />
                <gradient
                    android:startColor="@color/surface29"
                    android:centerColor="@color/surface29"
                    android:centerY="0.75"
                    android:endColor="@color/surface29"
                    android:angle="270" />
            </shape>
        </clip>
    </item>
</layer-list>
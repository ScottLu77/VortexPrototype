        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text01</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="CollapsingToolbarCollapsedTitleText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CollapsingToolbarExpandedTitleText">
        <item name="android:textSize">34sp</item>
        <item name="android:textColor">@color/text01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavigationItemText">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BlockView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/block_view</item>

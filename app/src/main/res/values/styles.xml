    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/line01</item>
    </style>

    <style name="GeneralDialog" parent="@android:style/Theme.Dialog">
        <!-- 邊框 -->
        <item name="android:windowFrame">@null</item>
        <!-- 是否浮现在activity之上 -->
        <item name="android:windowIsFloating">true</item>
        <!-- 整個 layout 半透明 -->
        <item name="android:windowIsTranslucent">true</item>
        <!-- 拿掉標題 -->
        <item name="android:windowNoTitle">true</item>
        <!-- 背景 -->
        <item name="android:windowBackground">@android:color/white</item>
        <!-- 由 XML 設定 Dialog 視窗是否變暗 -->
        <item name="android:backgroundDimEnabled">true</item>
        <!-- 亮度從 0 到 1.0 -->
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <style name="AlertOnePositiveTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface03</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertTitleTextStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/AlertBodyTextStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertCheckStyle</item>
    </style>

    <style name="AlertOneNegativeOnePositiveTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface03</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="materialAlertDialogTitleTextStyle">@style/AlertTitleTextStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/AlertBodyTextStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/AlertCheckStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertWarningStyle</item>
    </style>

    <style name="TabLayout" parent="Base.Widget.Design.TabLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="tabTextColor">@color/subtitle1</item>

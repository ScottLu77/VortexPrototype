        <item name="android:focusable">true</item>
        <item name="android:elevation">20dp</item>
        <item name="android:contentDescription">@string/empty_string</item>
    </style>

    <style name="ProgressBarBig">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:indeterminateTint">@color/progress</item>
        <item name="android:elevation">20dp</item>
    </style>

    <style name="ProgressBarSmall">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:indeterminateTint">@color/white</item>
        <item name="android:elevation">20dp</item>
    </style>

    <style name="ProgressBarUnlockButton">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:indeterminateTint">@color/icon06</item>
        <item name="android:elevation">20dp</item>
    </style>

    <style name="BottomSheet">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/drop_surface01</item>
        <item name="android:clickable">true</item>
        <item name="android:elevation">20dp</item>
        <item name="android:focusable">true</item>
        <item name="android:orientation">vertical</item>
        <item name="android:showDividers">middle</item>
        <item name="android:divider">@color/line01</item>
        <item name="android:dividerPadding">0dp</item>
    </style>

    <style name="BottomSheetTitleText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textColor">@color/text01</item>
        <item name="android:textSize">20sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="BottomSheetList" parent="List">
        <item name="android:background">@null</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="BottomSheetItemText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textColor">@color/text01</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:drawableTint">@color/icon15</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <style name="Subtitle2LeftMedium">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:paddingBottom">8dp</item>

<resources>
    <!-- Base application theme. -->
    <style name="Theme.AndroidCharmander" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- Primary brand color. -->
        <item name="colorPrimaryDark">@color/surface03</item>
        <item name="colorPrimaryVariant">@color/surface03</item>
        <!-- Secondary brand color. -->
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/surface03</item>
        <!-- Customize your theme here. -->
        <item name="android:fontFamily">sans-serif</item>
        <!-- <item name="android:windowAnimationStyle">@null</item> -->
        <item name="android:colorBackground">?attr/colorPrimaryDark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowLightStatusBar">@bool/light_status_bar</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.App.Button.OutlinedButton</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>
    
    <style name="Theme.App.Starting" parent="Theme.AndroidCharmander" />
</resources>